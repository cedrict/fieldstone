#
set term pdf enhanced font "Times,12pt"
set grid
set log y
set pointsize .23
set xlabel '#iter'

set ylabel 'xi_u'
set output 'conv_u.pdf'
plot[][]\
'120x30/conv.ascii' u 1:2 w lp t 'xi_u, 120x30',\
'160x40/conv.ascii' u 1:2 w lp t 'xi_u, 160x40',\
'200x50/conv.ascii' u 1:2 w lp t 'xi_u, 200x50',\
1e-4 w l lt -1 lw 2 dt 2 t 'tol'

