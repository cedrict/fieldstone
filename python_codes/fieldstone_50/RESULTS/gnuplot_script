'160x40/conv.ascii' u 1:4 w lp t 'xi_p, 160x40',\
'200x50/conv.ascii' u 1:4 w lp t 'xi_p, 200x50',\
1e-4 w l lt -1 lw 2 dt 2 t 'tol'

